[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/hud_view.gd" id="1_hud"]

[node name="HUDView" type="PanelContainer"]
script = ExtResource("1_hud")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 4

[node name="LogLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)
text = ""

[node name="ControlRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="TurnLabel" type="Label" parent="VBox/ControlRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Your turn"

[node name="EndTurnBtn" type="Button" parent="VBox/ControlRow"]
layout_mode = 2
custom_minimum_size = Vector2(160, 48)
text = "End turn"

[node name="PauseBtn" type="Button" parent="VBox/ControlRow"]
layout_mode = 2
custom_minimum_size = Vector2(48, 48)
text = "||"
